{
    "$schema": "node_modules/wrangler/config-schema.json",
    "main": ".open-next/worker.js",
    "name": "perpl",
    "compatibility_date": "2024-12-30",
    "compatibility_flags": [
        "nodejs_compat",
        "global_fetch_strictly_public"
    ],
    "assets": {
        "directory": ".open-next/assets",
        "binding": "ASSETS"
    },
    "services": [
        {
            "binding": "WORKER_SELF_REFERENCE",
            "service": "perpl"
        }
    ],
    "kv_namespaces": [
        {
            "binding": "YOUTUBE_CACHE",
            "id": "production-namespace-id-placeholder",
            "preview_id": "preview-namespace-id-placeholder"
        }
    ]
}